# ========================================
# Supabase Configuration
# ========================================
# Copy your Supabase project credentials from https://app.supabase.com
# These must be set for the app to function
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_service_xxxxx

# ========================================
# JWT Configuration
# ========================================
# Use a strong random string (minimum 32 characters)
# For Cloudflare Workers: use SUPABASE_SERVICE_ROLE_KEY or generate a new secret
JWT_SECRET=your_strong_32_character_secret_key_here_minimum

# ========================================
# Backend API Configuration
# ========================================
# Leave empty to use local /api endpoints (default for development and Cloudflare)
# Set to your backend URL only if using external backend service
NEXT_PUBLIC_API_URL=

# ========================================
# Node Environment
# ========================================
# Use 'development' for local dev, 'production' for Cloudflare deployment
NODE_ENV=development

# ========================================
# Application URL
# ========================================
# For local development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# For Cloudflare Workers deployment, update to:
# NEXT_PUBLIC_APP_URL=https://pettypet.workers.dev
# For Cloudflare Pages deployment, update to:
# NEXT_PUBLIC_APP_URL=https://pettypet.pages.dev

# ========================================
# Cloudflare Configuration (for Workers deployment)
# ========================================
# Account ID and API token are stored in GitHub Actions secrets
# See DEPLOYMENT_QUICK_START.md for setup instructions
# CLOUDFLARE_ACCOUNT_ID=xxxxx (stored in GitHub secrets)
# CLOUDFLARE_API_TOKEN=xxxxx (stored in GitHub secrets)

# ========================================
# Debug & Development
# ========================================
# Set to true to enable verbose logging (development only)
DEBUG=false

