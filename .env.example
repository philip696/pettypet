# ========================================
# Supabase Configuration
# ========================================
# Copy your Supabase project credentials from https://app.supabase.com
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ========================================
# JWT Configuration
# ========================================
# Use a strong random string (minimum 32 characters)
JWT_SECRET=your_jwt_secret_key_here

# ========================================
# Backend API Configuration
# ========================================
# Leave empty to use local /api endpoints (default for development)
# Set to your backend URL for production (e.g., Railway, Vercel API)
# Example: https://api.pettypet.com or https://pettypet-backend.railway.app
NEXT_PUBLIC_API_URL=

# ========================================
# Node Environment
# ========================================
NODE_ENV=production

# ========================================
# Application URL (Optional - for OAuth redirects)
# ========================================
NEXT_PUBLIC_APP_URL=https://your-vercel-url.vercel.app

